{
  "name": "ymda",
  "version": "1.0.0",
  "description": "YouTube Music Desktop App — custom Electron wrapper with lyrics & OBS overlay",
  "main": "src/main/main.js",
  "author": "Fishstick",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.fishstick.ymda",
    "productName": "YMDA",
    "copyright": "© 2025 Fishstick",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  }
}
